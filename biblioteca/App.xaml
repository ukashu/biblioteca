<Application x:Class="biblioteca.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:biblioteca"
             xmlns:views="clr-namespace:biblioteca.Views"
             xmlns:viewModels="clr-namespace:biblioteca.ViewModels"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <DataTemplate DataType="{x:Type viewModels:BookListViewModel}">
            <views:BookList/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:UserListViewModel}">
            <views:UserList/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReturnBooksViewModel}">
            <views:ReturnBooks/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:BorrowingHistoryViewModel}">
            <views:BorrowingHistory/>
        </DataTemplate>
         
    </Application.Resources>
</Application>
